{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mingli.local/schemas/ziwei_palace.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["palace_index", "palace_name", "heavenly_stem", "earthly_branch", "is_body_palace", "primary_stars", "supporting_stars", "malefic_stars", "transformations", "brightness_state", "field_status"],
  "properties": {
    "palace_index": {"type": "integer", "minimum": 0, "maximum": 11},
    "palace_name": {"type": "string", "minLength": 1},
    "heavenly_stem": {"type": ["string", "null"]},
    "earthly_branch": {"enum": ["寅", "卯", "辰", "巳", "午", "未", "申", "酉", "戌", "亥", "子", "丑"]},
    "is_body_palace": {"type": ["boolean", "null"]},
    "primary_stars": {"type": "array", "items": {"$ref": "#/$defs/star"}},
    "supporting_stars": {"type": "array", "items": {"$ref": "#/$defs/star"}},
    "malefic_stars": {"type": "array", "items": {"$ref": "#/$defs/star"}},
    "transformations": {"type": "array", "items": {"$ref": "#/$defs/transformation"}},
    "brightness_state": {"type": "array", "items": {"$ref": "#/$defs/brightness"}},
    "field_status": {"enum": ["supported", "unsupported", "research_required"]}
  },
  "$defs": {
    "sources": {"type": "array", "minItems": 1, "items": {"type": "string"}, "uniqueItems": true},
    "star": {"type": "object", "additionalProperties": false, "required": ["star_id", "star_name", "category", "field_status", "source_provenance"], "properties": {"star_id": {"type": "string"}, "star_name": {"type": "string"}, "category": {"enum": ["primary", "supporting", "malefic"]}, "field_status": {"enum": ["supported", "unsupported", "research_required"]}, "source_provenance": {"$ref": "#/$defs/sources"}}},
    "transformation": {"type": "object", "additionalProperties": false, "required": ["transformation", "star_id", "field_status", "source_provenance"], "properties": {"transformation": {"enum": ["lu", "quan", "ke", "ji"]}, "star_id": {"type": "string"}, "field_status": {"enum": ["supported", "unsupported", "research_required"]}, "source_provenance": {"$ref": "#/$defs/sources"}}},
    "brightness": {"type": "object", "additionalProperties": false, "required": ["star_id", "state", "source_value", "field_status", "source_provenance"], "properties": {"star_id": {"type": "string"}, "state": {"enum": ["temple", "prosperous", "beneficial", "neutral", "weak", "unfavorable", "fallen", "unsupported"]}, "source_value": {"type": "string"}, "field_status": {"enum": ["supported", "unsupported", "research_required"]}, "source_provenance": {"$ref": "#/$defs/sources"}}}
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mingli.local/schemas/validation_dataset_manifest.schema.json",
  "title": "Frozen Validation Dataset Manifest",
  "type": "object",
  "required": ["dataset_id", "dataset_version", "freeze_status", "frozen_at", "source_commit_sha", "case_count", "unique_person_count", "gold_unique_person_count", "silver_unique_person_count", "bronze_count", "comparable_claims_count", "scenario_coverage", "review_coverage_passed", "privacy_coverage_passed", "conflicting_person_tiers", "excluded_cases", "withdrawn_cases", "case_manifest_hashes", "prediction_snapshot_hashes", "reality_evidence_hashes", "review_hashes", "aggregate_canonical_hash"],
  "properties": {
    "dataset_id": {"type": "string"},
    "dataset_version": {"type": "string"},
    "freeze_status": {"const": "frozen"},
    "frozen_at": {"type": "string", "format": "date-time"},
    "source_commit_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "case_count": {"type": "integer", "minimum": 0},
    "unique_person_count": {"type": "integer", "minimum": 0},
    "gold_unique_person_count": {"type": "integer", "minimum": 0},
    "silver_unique_person_count": {"type": "integer", "minimum": 0},
    "bronze_count": {"type": "integer", "minimum": 0},
    "comparable_claims_count": {"type": "integer", "minimum": 0},
    "scenario_coverage": {"type": "array"},
    "review_coverage_passed": {"type": "boolean"},
    "privacy_coverage_passed": {"type": "boolean"},
    "conflicting_person_tiers": {"type": "array"},
    "excluded_cases": {"type": "integer", "minimum": 0},
    "withdrawn_cases": {"type": "integer", "minimum": 0},
    "case_manifest_hashes": {"type": "array"},
    "prediction_snapshot_hashes": {"type": "array"},
    "reality_evidence_hashes": {"type": "array"},
    "review_hashes": {"type": "array"},
    "aggregate_canonical_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
  },
  "additionalProperties": true
}

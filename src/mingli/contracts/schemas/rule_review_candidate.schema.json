{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mingli.local/schemas/rule_review_candidate.schema.json",
  "title": "RuleReviewCandidate",
  "type": "object",
  "required": ["candidate_id", "source_case_ids", "suspected_failure_mode", "current_rule_ids", "proposed_change", "supporting_evidence", "counter_evidence", "confidence", "review_state", "reviewer_note", "created_at", "applied_to_rules", "valid"],
  "properties": {
    "candidate_id": {"type": "string", "minLength": 1},
    "source_case_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^person:[0-9a-f]{64}$"}},
    "suspected_failure_mode": {"type": "string", "minLength": 1},
    "current_rule_ids": {"type": "array", "items": {"type": "string"}},
    "proposed_change": {"type": "string", "minLength": 1},
    "supporting_evidence": {"type": "array", "items": {"type": "string"}},
    "counter_evidence": {"type": "array", "items": {"type": "string"}},
    "confidence": {"enum": ["high", "medium", "low"]},
    "review_state": {"enum": ["pending_human_review", "approved_for_manual_application", "rejected"]},
    "reviewer_note": {"type": ["string", "null"]},
    "created_at": {"type": "string", "format": "date-time"},
    "applied_to_rules": {"const": false},
    "valid": {"type": "boolean"}
  },
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mingli.local/schemas/prediction_snapshot.schema.json",
  "title": "Immutable Prediction Snapshot",
  "type": "object",
  "required": ["prediction_id", "person_case_id", "scenario_id", "engine_version", "source_commit_sha", "rule_set_version", "knowledge_manifest_sha", "input_manifest_sha", "generated_at", "prediction_content", "structured_claims", "confidence", "blocked_fields", "reality_evidence_visibility", "freeze_status", "freeze_timestamp", "canonical_hash"],
  "properties": {
    "prediction_id": {"type": "string", "minLength": 1},
    "person_case_id": {"type": "string", "pattern": "^person:"},
    "scenario_id": {"type": "string", "minLength": 1},
    "engine_version": {"type": "string"},
    "source_commit_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "rule_set_version": {"type": "string"},
    "knowledge_manifest_sha": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "input_manifest_sha": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "generated_at": {"type": "string", "format": "date-time"},
    "prediction_content": {"type": "string"},
    "structured_claims": {"type": "array", "minItems": 1},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "blocked_fields": {"type": "array"},
    "reality_evidence_visibility": {"const": false},
    "freeze_status": {"const": "frozen"},
    "freeze_timestamp": {"type": "string", "format": "date-time"},
    "canonical_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
  },
  "additionalProperties": true
}

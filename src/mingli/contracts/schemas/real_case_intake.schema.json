{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mingli.local/schemas/real_case_intake.schema.json",
  "title": "Real Case Intake",
  "type": "object",
  "required": ["person_case_id", "birth_input", "consent", "case_metadata", "scenarios"],
  "properties": {
    "person_case_id": {"type": "string", "pattern": "^person:[A-Za-z0-9._:-]{3,128}$"},
    "birth_input": {"type": "object"},
    "consent": {"type": "object"},
    "case_metadata": {"type": "object"},
    "scenarios": {"type": "array", "minItems": 1, "items": {"type": "object"}}
  },
  "additionalProperties": false
}

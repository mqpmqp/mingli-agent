{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mingli.local/schemas/user_feedback.schema.json",
  "title": "UserFeedback",
  "type": "object",
  "required": ["feedback_id", "case_id", "run_id", "overall_rating", "useful_sections", "inaccurate_sections", "missing_context", "user_correction", "clarity_rating", "actionability_rating", "free_text", "feedback_kind", "submitted_at", "counts_toward_accuracy", "valid"],
  "properties": {
    "feedback_id": {"type": "string", "minLength": 1},
    "case_id": {"type": "string", "pattern": "^person:[0-9a-f]{64}$"},
    "run_id": {"type": "string", "minLength": 1},
    "overall_rating": {"type": "integer", "minimum": 1, "maximum": 5},
    "useful_sections": {"type": "array", "items": {"type": "string"}},
    "inaccurate_sections": {"type": "array", "items": {"type": "string"}},
    "missing_context": {"type": "array", "items": {"type": "string"}},
    "user_correction": {"type": ["string", "null"]},
    "clarity_rating": {"type": "integer", "minimum": 1, "maximum": 5},
    "actionability_rating": {"type": "integer", "minimum": 1, "maximum": 5},
    "free_text": {"type": ["string", "null"]},
    "feedback_kind": {"enum": ["subjective", "historical_correction"]},
    "submitted_at": {"type": "string", "format": "date-time"},
    "counts_toward_accuracy": {"const": false},
    "valid": {"type": "boolean"}
  },
  "additionalProperties": false
}

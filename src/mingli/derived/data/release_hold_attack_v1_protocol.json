    "reality_evidence_coverage": "observable claims with scope-matched reality evidence divided by observable claims",
    "unverifiable_rate": "insufficient_evidence plus not_comparable divided by observable claims",
    "calibration": ["brier_score", "expected_calibration_error"]
  },
  "hold_reassessment": {
    "automatic_release": false,
    "thresholds": {
      "minimum_unique_persons": 30,
      "minimum_gold_persons": 10,
      "maximum_silver_persons": 20,
      "minimum_comparable_claims": 100,

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Judgement",
  "type": "object",
  "required": [
    "claim",
    "confidence",
    "evidence",
    "plain_language"
  ],
  "properties": {
    "claim": {
      "type": "string"
    },
    "confidence": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low"
      ]
    },
    "evidence": {
      "type": "array",
      "items": {
        "$ref": "evidence.schema.json"
      }
    },
    "plain_language": {
      "type": "string"
    },
    "reality_dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recommended_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}

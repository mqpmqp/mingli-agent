{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RuleCard",
  "type": "object",
  "required": [
    "id",
    "domain",
    "trigger",
    "judgement",
    "plain_language",
    "confidence",
    "status"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "domain": {
      "type": "string"
    },
    "trigger": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "support": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "exclude": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "judgement": {
      "type": "string"
    },
    "plain_language": {
      "type": "string"
    },
    "confidence": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low"
      ]
    },
    "priority": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100
    },
    "source": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "reviewed",
        "verified",
        "deprecated"
      ]
    }
  },
  "additionalProperties": false
}

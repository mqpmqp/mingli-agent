{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CandidateRule",
  "type": "object",
  "required": [
    "candidate_id",
    "source_ids",
    "trigger",
    "judgement",
    "plain_language",
    "review_status"
  ],
  "properties": {
    "candidate_id": {
      "type": "string"
    },
    "source_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "trigger": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "support": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "exclude": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "judgement": {
      "type": "string"
    },
    "plain_language": {
      "type": "string"
    },
    "claimed_school": {
      "type": [
        "string",
        "null"
      ]
    },
    "evidence_level": {
      "type": "string",
      "enum": [
        "source_only",
        "multi_source",
        "case_supported",
        "backtested"
      ]
    },
    "review_status": {
      "type": "string",
      "enum": [
        "draft",
        "needs_source",
        "reviewed",
        "verified",
        "rejected"
      ]
    },
    "benchmark_required": {
      "type": "boolean",
      "default": true
    }
  },
  "additionalProperties": false
}
